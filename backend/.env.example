# --- Core ---
NODE_ENV=development
PORT=3000

# --- Database (required) ---
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/chattify

# --- Auth (required) ---
# Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# --- Cookies ---
# Set to "true" once your frontend and backend are on different domains over HTTPS.
COOKIE_SECURE=false
# Only needed if frontend/backend share a parent domain, e.g. ".yourapp.com"
# COOKIE_DOMAIN=

# --- CORS ---
# Comma-separated list of exact frontend origins allowed to call this API.
CLIENT_URLS=http://localhost:5173,http://127.0.0.1:5173

# --- Scaling (optional) ---
# Set this to enable the Socket.IO Redis adapter for running multiple server
# instances behind a load balancer. Requires: npm install @socket.io/redis-adapter redis
# REDIS_URL=redis://localhost:6379
